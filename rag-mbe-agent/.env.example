# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
API_PORT=8000

# ── Ollama / LLM ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_DELAY=2.0

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=dmis-lab/biobert-base-cased-v1.2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── FAISS ─────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=/app/data/faiss_index
FAISS_TOP_K=5
FAISS_SIMILARITY_THRESHOLD=0.30

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mbe_agent
POSTGRES_USER=mbe_user
POSTGRES_PASSWORD=mbe_pass
DB_MAX_RETRIES=5
DB_RETRY_DELAY=3.0
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Memory ────────────────────────────────────────────────────────────────────
SHORT_TERM_HISTORY_N=10

# ── Agent ─────────────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=es
MBE_CLASSIFIER_THRESHOLD=0.6
MAX_RETRIES_AGENT=3
